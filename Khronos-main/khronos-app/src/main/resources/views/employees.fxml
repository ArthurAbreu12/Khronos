<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.khronos.controller.EmployeeController"
      spacing="22"
      alignment="TOP_CENTER"
      styleClass="tab-content">

    <padding>
        <Insets top="28" right="28" bottom="28" left="28"/>
    </padding>

    <!-- Título -->
    <Label text="FUNCIONÁRIOS"
           styleClass="brand-title"/>

    <!-- Card -->
    <VBox spacing="18"
          maxWidth="760"
          styleClass="form-card">

        <GridPane hgap="18" vgap="14">

            <columnConstraints>
                <ColumnConstraints minWidth="90"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Nome -->
            <Label text="Nome"
                   styleClass="form-label"
                   GridPane.rowIndex="0"
                   GridPane.columnIndex="0"/>

            <TextField fx:id="txtNome"
                       promptText="Nome do funcionário"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="1"
                       maxWidth="Infinity"/>

            <!-- Cargo -->
            <Label text="Cargo"
                   styleClass="form-label"
                   GridPane.rowIndex="1"
                   GridPane.columnIndex="0"/>

            <TextField fx:id="txtCargo"
                       promptText="Cargo"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="1"
                       maxWidth="Infinity"/>

            <!-- Salário -->
            <Label text="Salário"
                   styleClass="form-label"
                   GridPane.rowIndex="2"
                   GridPane.columnIndex="0"/>

            <TextField fx:id="txtSalario"
                       promptText="0,00"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="1"
                       maxWidth="Infinity"/>

        </GridPane>

        <!-- Botões -->
        <HBox spacing="12"
              alignment="CENTER_LEFT">

            <Button text="Cadastrar"
                    fx:id="btnCadastrar"
                    onAction="#onCadastrar"
                    styleClass="btn-start"
                    prefWidth="145"/>

            <Button text="Atualizar"
                    onAction="#onAtualizar"
                    styleClass="btn-ghost"
                    prefWidth="145"/>

            <Button text="Limpar"
                    onAction="#onLimpar"
                    styleClass="btn-ghost"
                    prefWidth="145"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Demitir"
                    onAction="#onDemitir"
                    styleClass="btn-stop"
                    prefWidth="145"/>

        </HBox>

    </VBox>

    <!-- Tabela -->
    <VBox spacing="10"
          VBox.vgrow="ALWAYS"
          maxWidth="900">

        <Label text="Funcionários cadastrados"
               styleClass="section-title"/>

        <TableView fx:id="tblEmployees"
                   VBox.vgrow="ALWAYS">

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>

            <columns>

                <TableColumn fx:id="colId"
                             text="ID"
                             maxWidth="70"/>

                <TableColumn fx:id="colNome"
                             text="Nome"/>

                <TableColumn fx:id="colCargo"
                             text="Cargo"/>

                <TableColumn fx:id="colSalario"
                             text="Salário"/>

                <TableColumn fx:id="colAtivo"
                             text="Ativo"
                             maxWidth="90"/>

            </columns>

        </TableView>

    </VBox>

</VBox>